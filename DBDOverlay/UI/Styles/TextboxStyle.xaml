<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:custom="clr-namespace:DBDOverlay.Core.CustomItems">

    <custom:GreaterThanZeroToVisibilityConverter x:Key="GreaterThanZeroToVisibility"/>

    <Style x:Key="TextBoxInputStyle" TargetType="{x:Type TextBox}">
        <Setter Property="Background" Value="{StaticResource WhiteGrayBrush}"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="CaretBrush" Value="White"/>
        <Setter Property="Padding" Value="5,0,5,0"/>
        <Setter Property="BorderThickness" Value="0,0,0,1"/>
        <Setter Property="TextWrapping" Value="NoWrap"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate x:Name="TextBoxTemplate" TargetType="{x:Type TextBox}">
                    <Border x:Name="Border" 
                            Background="Transparent" 
                            Focusable="True" 
                            BorderThickness="{TemplateBinding BorderThickness}" 
                            BorderBrush="{TemplateBinding Background}" 
                            SnapsToDevicePixels="True" 
                            Cursor="IBeam">
                        <Grid>
                            <ScrollViewer x:Name="PART_ContentHost" 
                                          Focusable="false" 
                                          HorizontalScrollBarVisibility="Hidden" 
                                          VerticalScrollBarVisibility="Hidden"
                                          VerticalAlignment="Center"/>
                            <TextBlock x:Name="Placeholder"
                                       Text="{TemplateBinding Tag}"
                                       Margin="4,0,0,0"
                                       Foreground="{StaticResource LightGrayBrush}"
                                       IsHitTestVisible="False"
                                       VerticalAlignment="Center"
                                       Visibility="Collapsed"/>
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="BorderBrush" TargetName="Border" Value="White"/>
                        </Trigger>
                        <Trigger Property="Text" Value="">
                            <Setter TargetName="Placeholder" Property="Visibility" Value="Visible"/>
                        </Trigger>
                        <Trigger Property="IsKeyboardFocused" Value="True">
                            <Setter TargetName="Placeholder" Property="Visibility" Value="Collapsed"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Border" Property="BorderBrush" Value="{StaticResource WhiteGrayBrush}"/>
                            <Setter TargetName="Border" Property="Background" Value="{StaticResource DisabledGrayBackgroundBrush}"/>
                            <Setter Property="Foreground" Value="{StaticResource WhiteGrayBrush}"/>
                            <Setter Property="Cursor" Value="Arrow"/>
                            <Setter Property="Opacity" Value="0.8"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="TextBoxKeyStyle" TargetType="TextBox" BasedOn="{StaticResource TextBoxInputStyle}">
        <Setter Property="IsReadOnly" Value="True"/>
        <Setter Property="IsReadOnlyCaretVisible" Value="False"/>
        <Setter Property="IsUndoEnabled" Value="False"/>
        <Setter Property="ToolTipService.InitialShowDelay" Value="300"/>
        <Setter Property="ToolTip">
            <Setter.Value>
                <ToolTip Style="{DynamicResource ToolTipStyle}">
                    <StackPanel>
                        <TextBlock FontWeight="Bold" 
                                   Style="{DynamicResource ToolTipTextBlockStyle}">
                            To change shortcut key:
                        </TextBlock>
                        <TextBlock Style="{DynamicResource ToolTipTextBlockStyle}">
                            - Click
                        </TextBlock>
                        <TextBlock Style="{DynamicResource ToolTipTextBlockStyle}">
                            - Press key
                        </TextBlock>
                    </StackPanel>
                </ToolTip>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsFocused" Value="True">
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="Padding" Value="0"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="TextBoxScrollBarThumb" TargetType="{x:Type Thumb}">
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="OverridesDefaultStyle" Value="true" />
        <Setter Property="IsTabStop" Value="false" />
        <Setter Property="Focusable" Value="false" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Thumb}">
                    <Border
                        Background="{TemplateBinding Background}"
                        BorderThickness="0"/>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="HorizontalTextBoxScrollBarStyle" TargetType="{x:Type ScrollBar}">
        <Setter Property="Orientation" Value="Horizontal"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ScrollBar}">
                    <Track x:Name="PART_Track"
                           IsDirectionReversed="false">
                        <Track.Thumb>
                            <Thumb x:Name="ScrollThumb"
                                   Style="{StaticResource TextBoxScrollBarThumb}"
                                   Margin="0,2,0,0"
                                   Height="6"
                                   Background="{StaticResource DarkLightGrayBrush}"/>
                        </Track.Thumb>
                    </Track>

                    <ControlTemplate.Triggers>
                        <Trigger Property="UIElement.IsMouseOver" Value="True">
                            <Setter TargetName="ScrollThumb"
                                    Property="Background"
                                    Value="{StaticResource GrayBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="TextBoxReadOnlyStyle" TargetType="{x:Type custom:ReadOnlyTextBox}">
        <Setter Property="Background" Value="{StaticResource WhiteGrayBrush}"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="CaretBrush" Value="White"/>
        <Setter Property="Padding" Value="4"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="IsReadOnly" Value="True"/>
        <Setter Property="TextWrapping" Value="NoWrap"/>
        <Setter Property="BorderThickness" Value="0,0,0,1"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate x:Name="TextBoxTemplate" TargetType="{x:Type custom:ReadOnlyTextBox}">
                    <Grid>
                        <Border x:Name="Border" 
                                Background="Transparent" 
                                Focusable="True" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                BorderBrush="{TemplateBinding Background}" 
                                SnapsToDevicePixels="True" 
                                Cursor="IBeam">
                            <ScrollViewer x:Name="PART_ContentHost" 
                                      Focusable="false" 
                                      HorizontalScrollBarVisibility="Auto" 
                                      VerticalScrollBarVisibility="Hidden"
                                      VerticalAlignment="Bottom">
                            </ScrollViewer>
                        </Border>
                        <ScrollBar x:Name="PART_HorizontalScrollBar"
                                   Orientation="Horizontal"
                                   VerticalAlignment="Bottom"
                                   Margin="0,0,0,-10"
                                   Cursor="Hand" 
                                   Style="{StaticResource HorizontalTextBoxScrollBarStyle}"
                                   Maximum="{Binding ElementName=PART_ContentHost, Path=ScrollableWidth}"
                                   Value="{Binding ElementName=PART_ContentHost, Path=HorizontalOffset, Mode=OneWay}"
                                   ViewportSize="{Binding ElementName=PART_ContentHost, Path=ViewportWidth}"
                                   Visibility="{Binding ElementName=PART_ContentHost, Path=ScrollableWidth, Converter={StaticResource GreaterThanZeroToVisibility}}"/>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>