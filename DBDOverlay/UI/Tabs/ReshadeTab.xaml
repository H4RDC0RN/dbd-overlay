<UserControl x:Class="DBDOverlay.UI.Tabs.ReshadeTabView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:DBDOverlay.UI.Tabs"
             xmlns:custom="clr-namespace:DBDOverlay.Core.CustomItems"
             mc:Ignorable="d" 
             d:DesignHeight="400" d:DesignWidth="500"
             Background="{DynamicResource DarkestGrayBrush}">

    <Grid>
        <Grid.ColumnDefinitions>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="0.2*"/>
            <RowDefinition Height="0.4*"/>
            <RowDefinition Height="0.4*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="0.76*"/>
                <ColumnDefinition Width="0.24*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="0.6*"/>
                <RowDefinition Height="0.4*"/>
            </Grid.RowDefinitions>

            <custom:ReadOnlyTextBox Grid.Row="0"
                     Grid.Column="0"
                     HorizontalAlignment="Stretch"
                     VerticalAlignment="Center"
                     x:Name="ReShadePathTextBox"
                     Text="Test content Test content Test content Test content Test content Test content"
                     Height="30"
                     FontSize="14"
                     Margin="5,5,5,0"
                     Background="{StaticResource RedLightBrush}"
                     Style="{StaticResource TextBoxReadOnlyStyle}"/>

            <StackPanel Grid.Row="0"
                        Grid.Column="1"
                        Orientation="Horizontal"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Left">
                <Button Grid.Column="1"
                        HorizontalAlignment="Left"
                        x:Name="OpenFolderButton"
                        Style="{StaticResource ButtonStyle}"
                        VerticalAlignment="Center"
                        Width="30"
                        Height="30"
                        Margin="8,5,0,0"
                        Click="OpenFolder_Click">
                    <Button.Content>
                        <Image x:Name="OpenFolderImage" 
                               Source="/Images/App/open-folder.png">
                        </Image>
                    </Button.Content>
                </Button>

                <Button x:Name="ClearFolderButton"
                        Style="{StaticResource ButtonStyle}"
                        VerticalAlignment="Center"
                        Width="30"
                        Height="30"
                        Margin="5,5,0,0"
                        Click="ClearFolder_Click">
                    <Button.Content>
                        <Image x:Name="ClearFolderImage" 
                               Source="/Images/App/clear-folder.png">
                        </Image>
                    </Button.Content>
                </Button>
                <Button x:Name="RefreshFiltersButton"
                        Style="{StaticResource ButtonStyle}"
                        VerticalAlignment="Center"
                        Width="30"
                        Height="30"
                        Margin="5,5,0,0"
                        Click="RefreshFilters_Click">
                    <Button.Content>
                        <Image x:Name="RefreshFiltersImage" 
                               Source="/Images/App/refresh.png">
                        </Image>
                    </Button.Content>
                </Button>
            </StackPanel>

            <Label Grid.Row="1" 
                   Grid.Column="0"
                   x:Name="FiltersStatusLabel"
                   Content="Test text"
                   Foreground="White"
                   FontSize="12"
                   VerticalAlignment="Center"
                   HorizontalAlignment="Center"/>
        </Grid>

        <StackPanel Grid.Row="1"
                    VerticalAlignment="Stretch"
                    Margin="5">
            <StackPanel Orientation="Horizontal"
                        VerticalAlignment="Center">
                <TextBox Grid.Row="1"
                         x:Name="MainFilterNameTextBox"
                         Height="30"
                         Width="200"
                         FontSize="14"
                         Margin="0,0,5,5"
                         HorizontalAlignment="Left"
                         Style="{StaticResource TextBoxInputStyle}"
                         Tag="Type name for app filter"/>
                <Button Grid.Row="1"
                        x:Name="GenerateFilterButton"
                        Style="{StaticResource ButtonStyle}"
                        Content="Generate"
                        FontSize="14"
                        VerticalAlignment="Center"
                        Width="80"
                        Height="30"
                        Margin="5,0,0,5"
                        Click="GenerateFilter_Click"/>
                <Button Grid.Column="1"
                        x:Name="DeleteFilterButton"
                        Style="{StaticResource ButtonStyle}"
                        VerticalAlignment="Center"
                        Width="30"
                        Height="30"
                        Margin="5,0,0,5"
                        Click="DeleteFilter_Click">
                    <Button.Content>
                        <Image x:Name="DeleteFilterImage" 
                               Source="/Images/App/close.png">
                        </Image>
                    </Button.Content>
                </Button>
            </StackPanel>
            <TextBlock Style="{DynamicResource InfoTextBlockStyle}">
                Assign "Effect reload key" in Reshade settings
            </TextBlock>
            <TextBlock Style="{DynamicResource InfoTextBlockStyle}">
                Select this filter in Reshade
            </TextBlock>
            <TextBlock Style="{DynamicResource InfoTextBlockStyle}">
                It will be updated (not applied) each time when new map is recognized by this app
            </TextBlock>
            <TextBlock Style="{DynamicResource InfoTextBlockStyle}">
                After recognizing press "Effect reload key" to apply updated filter
            </TextBlock>
        </StackPanel>

        <!--<Button Grid.Row="1"
                x:Name="ResetButton"
                Style="{StaticResource ButtonStyle}"
                Content="Reset filters"
                FontSize="16"
                Foreground="White"
                VerticalAlignment="Center"
                HorizontalAlignment="Right"
                Width="100"
                Height="30"
                Margin="5"
                Click="Reset_Click"/>-->

        <ScrollViewer x:Name="FiltersScrollViewer"
                      Grid.Row="2"
                      Style="{StaticResource ScrollViewerStyle}">
            <Grid x:Name="MapFiltersGrid">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                </Grid.RowDefinitions>
            </Grid>
        </ScrollViewer>
    </Grid>

</UserControl>
