<UserControl x:Class="DBDOverlay.UI.Tabs.ReshadeTabView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:DBDOverlay.UI.Tabs"
             xmlns:custom="clr-namespace:DBDOverlay.Core.CustomItems"
             mc:Ignorable="d" 
             d:DesignHeight="400" d:DesignWidth="500"
             Background="{DynamicResource DarkestGrayBrush}">

    <Grid Margin="5,0,0,0">
        <Grid.ColumnDefinitions>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="0.4*"/>
            <RowDefinition Height="0.6*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="0.74*"/>
                <ColumnDefinition Width="0.26*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <RowDefinition Height="40"/>
                <RowDefinition Height="40"/>
            </Grid.RowDefinitions>

            <custom:ReadOnlyTextBox Grid.Row="0"
                     Grid.Column="0"
                     HorizontalAlignment="Stretch"
                     VerticalAlignment="Center"
                     x:Name="ReShadePathTextBox"
                     Text="Test content Test content Test content Test content Test content Test content"
                     Height="30"
                     FontSize="14"
                     Margin="5,2,5,0"
                     Background="{StaticResource RedLightBrush}"
                     Style="{StaticResource TextBoxReadOnlyStyle}"/>

            <StackPanel Grid.Row="0"
                        Grid.Column="1"
                        Orientation="Horizontal"
                        HorizontalAlignment="Left">
                <Button x:Name="OpenFolderButton"
                        Width="30"
                        Height="30"
                        Margin="5,0,5,0"
                        Style="{StaticResource ButtonBackStyle}"
                        Click="OpenFolder_Click">
                    <Button.Content>
                        <Image x:Name="OpenFolderImage" 
                               Source="/Images/App/open-folder.png">
                        </Image>
                    </Button.Content>
                </Button>

                <Button x:Name="ClearFolderButton"
                        Width="30"
                        Height="30"
                        Margin="0,0,5,0"
                        Style="{StaticResource ButtonBackStyle}"
                        Click="ClearFolder_Click">
                    <Button.Content>
                        <Image x:Name="ClearFolderImage" 
                               Source="/Images/App/clear-folder.png">
                        </Image>
                    </Button.Content>
                </Button>
                <Button x:Name="RefreshFiltersButton"
                        Width="30"
                        Height="30"
                        Style="{StaticResource ButtonBackStyle}"
                        Click="RefreshFilters_Click">
                    <Button.Content>
                        <Image x:Name="RefreshFiltersImage" 
                               Source="/Images/App/refresh.png">
                        </Image>
                    </Button.Content>
                </Button>
            </StackPanel>

            <Label Grid.Row="1" 
                   Grid.Column="0"
                   x:Name="FiltersStatusLabel"
                   Content="Test text"
                   Foreground="White"
                   FontSize="12"
                   Margin="0,2,0,0"
                   VerticalAlignment="Center"
                   HorizontalAlignment="Center"/>

            <Button Grid.Row="1"
                    Grid.Column="1"
                    x:Name="AssignFiltersButton"
                    Style="{StaticResource ButtonBackStyle}"
                    Content="Assign filters"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Center"
                    Width="104"
                    Height="30"
                    FontSize="14"
                    Click="AssignFilters_Click"/>

            <TextBox Grid.Row="2"
                     Grid.Column="0"
                     x:Name="MainFilterNameTextBox"
                     Height="30"
                     Width="200"
                     FontSize="14"
                     Margin="0,0,5,5"
                     HorizontalAlignment="Center"
                     Style="{StaticResource TextBoxInputStyle}"
                     MaxLength="20"
                     Tag="Type name for app filter"/>

            <StackPanel Grid.Row="2"
                        Grid.Column="1"
                        Orientation="Horizontal"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center">
                <Button x:Name="GenerateFilterButton"
                        Style="{StaticResource ButtonBackStyle}"
                        Content="Generate"
                        FontSize="14"
                        Width="80"
                        Height="30"
                        Margin="0,0,5,0"
                        Click="GenerateFilter_Click"/>
                <Button x:Name="DeleteFilterButton"
                        Width="30"
                        Height="30"
                        Style="{StaticResource ButtonBackStyle}"
                        Click="DeleteFilter_Click">
                    <Button.Content>
                        <Image x:Name="DeleteFilterImage" 
                               Source="/Images/App/close.png">
                        </Image>
                    </Button.Content>
                </Button>
            </StackPanel>
        </Grid>

        <StackPanel Grid.Row="1"
                    VerticalAlignment="Stretch"
                    Margin="5">

            <TextBlock Style="{DynamicResource InfoTextBlockStyle}">
                Assign "Effect reload key" in Reshade settings
            </TextBlock>
            <TextBlock Style="{DynamicResource InfoTextBlockStyle}">
                Select this filter in Reshade
            </TextBlock>
            <TextBlock Style="{DynamicResource InfoTextBlockStyle}">
                It will be updated (not applied) each time when new map is recognized by this app
            </TextBlock>
            <TextBlock Style="{DynamicResource InfoTextBlockStyle}">
                After recognizing press "Effect reload key" to apply updated filter
            </TextBlock>
        </StackPanel>
    </Grid>
</UserControl>
